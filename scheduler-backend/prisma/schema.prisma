generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  schemas  = ["ems"]
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model assignments {
  id                String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schedule_id       String          @db.Uuid
  rotation_id       String          @db.Uuid
  user_id           String          @db.Uuid
  tier_id           String?         @db.Uuid
  assigned_start    DateTime        @db.Timestamptz(6)
  assigned_end      DateTime        @db.Timestamptz(6)
  is_override       Boolean?        @default(false)
  override_reason   String?
  created_at        DateTime?       @default(now()) @db.Timestamptz(6)
  assignment_status String          @default("ON_CALL") @db.VarChar(30)
  rotations         rotations       @relation(fields: [rotation_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  schedules         schedules       @relation(fields: [schedule_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  rotation_tiers    rotation_tiers? @relation(fields: [tier_id], references: [id], onUpdate: NoAction)
  users             users           @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([rotation_id], map: "idx_assignments_rotation_id")
  @@index([schedule_id], map: "idx_assignments_schedule_id")
  @@index([tier_id], map: "idx_assignments_tier_id")
  @@schema("ems")
}

model audit_logs {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actor_id     String?   @db.Uuid
  action       String    @db.VarChar(80)
  entity_type  String    @db.VarChar(80)
  entity_id    String?   @db.Uuid
  before_state Json?
  after_state  Json?
  created_at   DateTime? @default(now()) @db.Timestamptz(6)
  users        users?    @relation(fields: [actor_id], references: [id], onUpdate: NoAction)

  @@index([actor_id], map: "idx_audit_logs_actor")
  @@schema("ems")
}

model auth_identities {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id          String    @db.Uuid
  provider         String    @db.VarChar(50)
  provider_user_id String?   @db.VarChar(255)
  password_hash    String?
  created_at       DateTime? @default(now()) @db.Timestamptz(6)
  users            users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([provider, provider_user_id])
  @@unique([user_id, provider])
  @@index([user_id], map: "idx_auth_identities_user_id")
  @@schema("ems")
}

model conflicts {
  id                                 String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schedule_id                        String?    @db.Uuid
  rotation_id                        String?    @db.Uuid
  user_id                            String?    @db.Uuid
  conflict_type                      String     @db.VarChar(50)
  severity                           String     @default("MEDIUM") @db.VarChar(20)
  details                            Json?
  status                             String     @default("OPEN") @db.VarChar(20)
  created_at                         DateTime?  @default(now()) @db.Timestamptz(6)
  resolved_by                        String?    @db.Uuid
  resolved_at                        DateTime?  @db.Timestamptz(6)
  users_conflicts_resolved_byTousers users?     @relation("conflicts_resolved_byTousers", fields: [resolved_by], references: [id], onUpdate: NoAction)
  rotations                          rotations? @relation(fields: [rotation_id], references: [id], onUpdate: NoAction)
  schedules                          schedules? @relation(fields: [schedule_id], references: [id], onUpdate: NoAction)
  users_conflicts_user_idTousers     users?     @relation("conflicts_user_idTousers", fields: [user_id], references: [id], onUpdate: NoAction)

  @@index([resolved_by], map: "idx_conflicts_resolved_by")
  @@index([rotation_id], map: "idx_conflicts_rotation_id")
  @@index([schedule_id], map: "idx_conflicts_schedule_id")
  @@index([user_id], map: "idx_conflicts_user_id")
  @@schema("ems")
}

model coverage_gaps {
  id               String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  rotation_id      String          @db.Uuid
  leave_request_id String?         @db.Uuid
  gap_start        DateTime        @db.Date
  gap_end          DateTime        @db.Date
  is_filled        Boolean?        @default(false)
  filled_by        String?         @db.Uuid
  filled_at        DateTime?       @db.Timestamptz(6)
  created_at       DateTime?       @default(now()) @db.Timestamptz(6)
  users            users?          @relation(fields: [filled_by], references: [id], onUpdate: NoAction)
  leave_requests   leave_requests? @relation(fields: [leave_request_id], references: [id], onUpdate: NoAction)
  rotations        rotations       @relation(fields: [rotation_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([leave_request_id], map: "idx_coverage_gaps_leave_request_id")
  @@index([rotation_id], map: "idx_coverage_gaps_rotation_id")
  @@schema("ems")
}

model groups {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String            @unique @db.VarChar(255)
  description     String?
  timezone        String?           @default("UTC") @db.VarChar(64)
  is_active       Boolean?          @default(true)
  created_at      DateTime?         @default(now()) @db.Timestamptz(6)
  holidays        holidays[]
  rotation_scopes rotation_scopes[]
  rotations       rotations[]
  teams           teams[]

  @@schema("ems")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model holidays {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  group_id     String?   @db.Uuid
  holiday_date DateTime  @db.Date
  name         String    @db.VarChar(255)
  created_by   String?   @db.Uuid
  created_at   DateTime? @default(now()) @db.Timestamptz(6)
  holiday_type String?   @default("OTHER") @db.VarChar(50)
  users        users?    @relation(fields: [created_by], references: [id], onUpdate: NoAction)
  groups       groups?   @relation(fields: [group_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([created_by], map: "idx_holidays_created_by")
  @@index([group_id], map: "idx_holidays_group_id")
  @@schema("ems")
}

model leave_approvals {
  id               String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  leave_request_id String         @db.Uuid
  approver_id      String         @db.Uuid
  approval_level   Int            @default(1)
  decision         String         @db.VarChar(20)
  decided_at       DateTime?      @default(now()) @db.Timestamptz(6)
  comment          String?
  users            users          @relation(fields: [approver_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  leave_requests   leave_requests @relation(fields: [leave_request_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([leave_request_id, approver_id, approval_level])
  @@index([approver_id], map: "idx_leave_approvals_approver_id")
  @@index([leave_request_id], map: "idx_leave_approvals_leave_id")
  @@schema("ems")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model leave_requests {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id         String            @db.Uuid
  start_date      DateTime          @db.Date
  end_date        DateTime          @db.Date
  reason          String?
  status          String            @default("PENDING") @db.VarChar(30)
  requested_at    DateTime?         @default(now()) @db.Timestamptz(6)
  leave_period    String            @default("FULL_DAY") @db.VarChar(20)
  coverage_gaps   coverage_gaps[]
  leave_approvals leave_approvals[]
  users           users             @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id], map: "idx_leave_requests_user_id")
  @@schema("ems")
}

model notifications {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id             String    @db.Uuid
  message             String
  type                String    @db.VarChar(50)
  related_entity_type String?   @db.VarChar(80)
  related_entity_id   String?   @db.Uuid
  is_read             Boolean?  @default(false)
  created_at          DateTime? @default(now()) @db.Timestamptz(6)
  users               users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id], map: "idx_notifications_user_id")
  @@schema("ems")
}

model role_types {
  id           String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code         String         @unique @db.VarChar(64)
  name         String         @db.VarChar(128)
  description  String?
  created_at   DateTime?      @default(now()) @db.Timestamptz(6)
  team_members team_members[]
  user_roles   user_roles[]

  @@schema("ems")
}

model rotation_members {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  rotation_id    String    @db.Uuid
  user_id        String    @db.Uuid
  rotation_order Int
  is_active      Boolean?  @default(true)
  created_at     DateTime? @default(now()) @db.Timestamptz(6)
  rotations      rotations @relation(fields: [rotation_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users          users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([rotation_id, user_id])
  @@index([rotation_id], map: "idx_rotation_members_rotation_id")
  @@index([user_id], map: "idx_rotation_members_user_id")
  @@schema("ems")
}

model rotation_scopes {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  rotation_id String    @db.Uuid
  group_id    String?   @db.Uuid
  team_id     String?   @db.Uuid
  created_at  DateTime? @default(now()) @db.Timestamptz(6)
  groups      groups?   @relation(fields: [group_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  rotations   rotations @relation(fields: [rotation_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  teams       teams?    @relation(fields: [team_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([rotation_id, group_id, team_id])
  @@index([group_id], map: "idx_rotation_scopes_group_id")
  @@index([rotation_id], map: "idx_rotation_scopes_rotation_id")
  @@index([team_id], map: "idx_rotation_scopes_team_id")
  @@schema("ems")
}

model rotation_tier_members {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tier_id        String         @db.Uuid
  user_id        String         @db.Uuid
  rotation_order Int
  is_active      Boolean?       @default(true)
  created_at     DateTime?      @default(now()) @db.Timestamptz(6)
  rotation_tiers rotation_tiers @relation(fields: [tier_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users          users          @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([tier_id, user_id])
  @@index([tier_id], map: "idx_rotation_tier_members_tier_id")
  @@index([user_id], map: "idx_rotation_tier_members_user_id")
  @@schema("ems")
}

model rotation_tiers {
  id                    String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  rotation_id           String                  @db.Uuid
  tier_level            Int
  name                  String                  @db.VarChar(100)
  assignments           assignments[]
  rotation_tier_members rotation_tier_members[]
  rotations             rotations               @relation(fields: [rotation_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([rotation_id, tier_level])
  @@index([rotation_id], map: "idx_rotation_tiers_rotation_id")
  @@schema("ems")
}

model rotations {
  id                   String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                 String             @db.VarChar(255)
  rotation_type        String             @db.VarChar(50)
  group_id             String?            @db.Uuid
  team_id              String?            @db.Uuid
  cadence_type         String             @db.VarChar(50)
  cadence_interval     Int                @default(1)
  allow_overlap        Boolean?           @default(false)
  min_assignees        Int?               @default(1)
  allow_empty          Boolean?           @default(false)
  spans_multiple_teams Boolean?           @default(false)
  is_active            Boolean?           @default(true)
  created_at           DateTime?          @default(now()) @db.Timestamptz(6)
  assignments          assignments[]
  conflicts            conflicts[]
  coverage_gaps        coverage_gaps[]
  rotation_members     rotation_members[]
  rotation_scopes      rotation_scopes[]
  rotation_tiers       rotation_tiers[]
  groups               groups?            @relation(fields: [group_id], references: [id], onUpdate: NoAction)
  teams                teams?             @relation(fields: [team_id], references: [id], onUpdate: NoAction)
  schedules            schedules[]
  staffing_rules       staffing_rules[]

  @@index([group_id], map: "idx_rotations_group_id")
  @@index([team_id], map: "idx_rotations_team_id")
  @@schema("ems")
}

model schedules {
  id           String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  rotation_id  String        @db.Uuid
  window_start DateTime      @db.Date
  window_end   DateTime      @db.Date
  generated_at DateTime?     @default(now()) @db.Timestamptz(6)
  generated_by String?       @db.Uuid
  status       String        @default("DRAFT") @db.VarChar(30)
  assignments  assignments[]
  conflicts    conflicts[]
  users        users?        @relation(fields: [generated_by], references: [id], onUpdate: NoAction)
  rotations    rotations     @relation(fields: [rotation_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([rotation_id, window_start, window_end])
  @@index([generated_by], map: "idx_schedules_generated_by")
  @@index([rotation_id], map: "idx_schedules_rotation_id")
  @@schema("ems")
}

model staffing_rules {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  rotation_id String    @db.Uuid
  rule_type   String    @db.VarChar(50)
  rule_config Json
  is_active   Boolean?  @default(true)
  created_at  DateTime? @default(now()) @db.Timestamptz(6)
  rotations   rotations @relation(fields: [rotation_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([rotation_id], map: "idx_staffing_rules_rotation_id")
  @@schema("ems")
}

model team_members {
  id           String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id      String      @db.Uuid
  team_id      String      @db.Uuid
  role_type_id String?     @db.Uuid
  is_active    Boolean?    @default(true)
  created_at   DateTime?   @default(now()) @db.Timestamptz(6)
  role_types   role_types? @relation(fields: [role_type_id], references: [id], onUpdate: NoAction)
  teams        teams       @relation(fields: [team_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users        users       @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, team_id])
  @@index([role_type_id], map: "idx_team_members_role_type_id")
  @@index([team_id], map: "idx_team_members_team_id")
  @@index([user_id], map: "idx_team_members_user_id")
  @@schema("ems")
}

model teams {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  group_id        String?           @db.Uuid
  parent_team_id  String?           @db.Uuid
  name            String            @db.VarChar(255)
  description     String?
  timezone        String?           @db.VarChar(64)
  is_active       Boolean?          @default(true)
  created_at      DateTime?         @default(now()) @db.Timestamptz(6)
  rotation_scopes rotation_scopes[]
  rotations       rotations[]
  team_members    team_members[]
  groups          groups?           @relation(fields: [group_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  teams           teams?            @relation("teamsToteams", fields: [parent_team_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  other_teams     teams[]           @relation("teamsToteams")

  @@unique([group_id, name])
  @@index([group_id], map: "idx_teams_group_id")
  @@index([parent_team_id], map: "idx_teams_parent_team_id")
  @@schema("ems")
}

model user_roles {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id      String     @db.Uuid
  role_type_id String     @db.Uuid
  created_at   DateTime?  @default(now()) @db.Timestamptz(6)
  role_types   role_types @relation(fields: [role_type_id], references: [id], onUpdate: NoAction)
  users        users      @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, role_type_id])
  @@index([role_type_id], map: "idx_user_roles_role_type_id")
  @@index([user_id], map: "idx_user_roles_user_id")
  @@schema("ems")
}

model users {
  id                                     String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  first_name                             String                  @db.VarChar(100)
  last_name                              String                  @db.VarChar(100)
  email                                  String                  @unique @db.VarChar(255)
  is_active                              Boolean?                @default(true)
  created_at                             DateTime?               @default(now()) @db.Timestamptz(6)
  working_mode                           working_mode_enum       @default(LOCAL)
  city                                   String?                 @db.VarChar(100)
  province                               String?                 @db.VarChar(100)
  country                                String?                 @db.VarChar(100)
  assignments                            assignments[]
  audit_logs                             audit_logs[]
  auth_identities                        auth_identities[]
  conflicts_conflicts_resolved_byTousers conflicts[]             @relation("conflicts_resolved_byTousers")
  conflicts_conflicts_user_idTousers     conflicts[]             @relation("conflicts_user_idTousers")
  coverage_gaps                          coverage_gaps[]
  holidays                               holidays[]
  leave_approvals                        leave_approvals[]
  leave_requests                         leave_requests[]
  notifications                          notifications[]
  rotation_members                       rotation_members[]
  rotation_tier_members                  rotation_tier_members[]
  schedules                              schedules[]
  team_members                           team_members[]
  user_roles                             user_roles[]

  @@schema("ems")
}

enum working_mode_enum {
  LOCAL
  REMOTE
  HYBRID

  @@schema("ems")
}
